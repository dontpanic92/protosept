// Tests for `ref self` receivers on proto methods. After dropping the
// readonly axis, `ref self` is the only borrowed receiver form and permits
// mutation of fields through the borrow. Covers conformance, dynamic
// dispatch via `box<P>`, and direct method invocation.
import test.test;

proto Ticker {
    fn tick(ref self);
    fn value(ref self) -> int;
}

struct[Ticker] Tally(pub n: int) {
    pub fn tick(ref self) { self.n = self.n + 1; }
    pub fn value(ref self) -> int { return self.n; }
}

// Direct call on a `let mut` mutable place.
@test(expected_type = "int", expected_value = "2")
fn test_proto_ref_self_direct_let_mut() -> int {
    let mut t = Tally(0);
    t.tick();
    t.tick();
    return t.value();
}

// Dynamic dispatch via `box<P>` for a `ref self` proto method.
@test(expected_type = "int", expected_value = "3")
fn test_proto_ref_self_box_proto_dispatch() -> int {
    let bp: box<Ticker> = box(Tally(0)) as box<Ticker>;
    bp.tick();
    bp.tick();
    bp.tick();
    return bp.value();
}

// `box<Self>` (concrete) also works via the struct-method path.
@test(expected_type = "int", expected_value = "5")
fn test_proto_ref_self_box_concrete() -> int {
    let b = box(Tally(0));
    b.tick();
    b.tick();
    b.tick();
    b.tick();
    b.tick();
    return b.value();
}
