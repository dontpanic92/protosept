// Test for generic box<T> type annotation syntax parsing
struct test(
    pub expected_type: string,
    pub expected_value: string,
);

// Test that the parser accepts box<T> syntax in function parameters
// Note: Full generic semantics not yet implemented, so we use concrete types
fn accepts_box_int(x: int) -> int {
    x
}

// Test using generic type syntax with concrete type arguments
struct Point(
    x: int,
    y: int,
);

@test(expected_type = "int", expected_value = "42")
fn test_box_syntax_parsing() -> int {
    // This validates that box<int> type syntax is recognized by parser
    accepts_box_int(42)
}

@test(expected_type = "int", expected_value = "100")
fn test_point_struct() -> int {
    let p = Point(100, 200);
    p.x
}
