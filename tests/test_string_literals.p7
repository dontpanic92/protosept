// Test basic string literal support
import test.test;

@test(expected_type = "string", expected_value = "hello")
fn test_basic_string() -> string {
    "hello"
}

@test(expected_type = "string", expected_value = "world")
fn test_string_assignment() -> string {
    let s = "world";
    s
}

@test(expected_type = "string", expected_value = "Hello, World!")
fn test_string_with_punctuation() -> string {
    "Hello, World!"
}

@test(expected_type = "string", expected_value = "")
fn test_empty_string() -> string {
    ""
}

