// Define the test attribute struct
struct test(
    pub expected_type: string,
    pub expected_value: string,
);

fn id(x: ref float) -> float {
    *x
}

@test(expected_type = "float", expected_value = "1.1")
fn test_ref_param_direct() -> float {
    let a = 1.1;
    id(ref a)
}

@test(expected_type = "float", expected_value = "1.1")
fn test_ref_param_pass_view() -> float {
    let a = 1.1;
    let r = ref a;
    id(r)
}
