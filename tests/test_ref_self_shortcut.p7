// Define the test attribute struct
struct test(
  pub expected_type: string,
  pub expected_value: string,
);

struct Counter(
  value: int,
) {
  fn get1(ref self) -> int {
    self.value
  }

  fn get2(self: ref Self) -> int {
    self.value
  }
}

@test(expected_type = "int", expected_value = "10")
fn test_ref_self_shortcut() -> int {
  let c = Counter(value = 5);
  c.get1() + c.get2()
}
