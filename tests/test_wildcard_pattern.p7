/*
[testcase]
entrypoint = "test_wildcard"
expected_type = "int"
expected_value = "999"
*/

enum ErrorType {
    ErrorA,
    ErrorB,
    ErrorC,
}

fn[throws] thrower(value: int) -> int {
    if value == 1 {
        throw ErrorType.ErrorA;
    }
    if value == 2 {
        throw ErrorType.ErrorB;
    }
    if value == 3 {
        throw ErrorType.ErrorC;
    }
    value
}

fn test_wildcard() -> int {
    let result = try thrower(3) else {
        err: ErrorType.ErrorA => 10,
        err: ErrorType.ErrorB => 100,
        _: _ => 999,
    };
    result
}
