// Test newtype declarations
import test.test;

// Basic newtype declaration without representation
newtype Handle {
}

// Newtype with methods (but we won't call them yet)
newtype Counter {
    pub fn initial() -> int {
        return 0;
    }
}

// Newtype with representation
newtype UserId(int) {
}

// Generic newtype without representation
newtype Container<T> {
}

// Generic newtype with representation
newtype Wrapper<T>(T) {
}

@test(expected_type = "int", expected_value = "42")
fn test_type_parses() -> int {
    // Just test that the newtype declarations above parse correctly
    return 42;
}
