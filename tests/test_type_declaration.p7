// Test type declarations
import test.test;

// Basic type declaration with representation
type UserId(int) {
    pub fn new(id: int) -> UserId {
        return Self(id);
    }
    
    pub fn value(ref self) -> int {
        return self.0;
    }
}

@test(expected_type = "int", expected_value = "42")
fn test_type_basic() -> int {
    let uid = UserId::new(42);
    uid.value()
}

// Type with Copy conformance
type[Copy] Counter(int) {
    pub fn new(initial: int) -> Counter {
        return Self(initial);
    }
    
    pub fn get(ref self) -> int {
        return self.0;
    }
}

@test(expected_type = "int", expected_value = "10")
fn test_type_copy() -> int {
    let c = Counter::new(10);
    let c2 = c;  // Should be copyable
    c2.get()
}

// Type without representation
type Handle {
    pub fn dummy() -> int {
        return 99;
    }
}

@test(expected_type = "int", expected_value = "99")
fn test_type_no_repr() -> int {
    Handle::dummy()
}

// Generic type with representation
type Box<T>(T) {
    pub fn new(value: T) -> Box<T> {
        return Self(value);
    }
    
    pub fn get(ref self) -> T {
        return self.0;
    }
}

@test(expected_type = "int", expected_value = "100")
fn test_type_generic_int() -> int {
    let b = Box::new(100);
    b.get()
}

@test(expected_type = "float", expected_value = "3.14")
fn test_type_generic_float() -> float {
    let b = Box::new(3.14);
    b.get()
}
