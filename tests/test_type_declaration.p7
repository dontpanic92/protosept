// Test struct declarations (formerly type declarations)
import test.test;

// Basic struct declaration without fields
struct Handle;

// Struct with methods (but we won't call them yet)
struct Counter {
    pub fn initial() -> int {
        return 0;
    }
}

// Tuple struct with single field (newtype pattern)
struct UserId(int);

// Generic struct without fields
struct Container<T>;

// Generic tuple struct with representation
struct Wrapper<T>(T);

@test(expected_type = "int", expected_value = "42")
fn test_type_parses() -> int {
    // Just test that the struct declarations above parse correctly
    return 42;
}
