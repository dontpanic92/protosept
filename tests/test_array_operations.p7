// Tests for array operations: len, slice, push, clear
import test.test;

// === Tests for array.len() ===

@test(expected_type = "int", expected_value = "3")
fn test_array_len_basic() -> int {
    let arr = [1, 2, 3];
    arr.len()
}

@test(expected_type = "int", expected_value = "0")
fn test_array_len_empty() -> int {
    let arr: array<int> = [];
    arr.len()
}

@test(expected_type = "int", expected_value = "1")
fn test_array_len_single() -> int {
    let arr = [42];
    arr.len()
}

@test(expected_type = "int", expected_value = "5")
fn test_array_len_five_elements() -> int {
    let arr = [1, 2, 3, 4, 5];
    arr.len()
}

@test(expected_type = "int", expected_value = "3")
fn test_array_len_float_array() -> int {
    let arr = [1.0, 2.0, 3.0];
    arr.len()
}

// === Tests for array.slice() ===

@test(expected_type = "int", expected_value = "2")
fn test_array_slice_basic() -> int {
    let arr = [1, 2, 3, 4, 5];
    let sliced = arr.slice(1, 3);
    sliced[0]
}

@test(expected_type = "int", expected_value = "3")
fn test_array_slice_second_element() -> int {
    let arr = [1, 2, 3, 4, 5];
    let sliced = arr.slice(1, 3);
    sliced[1]
}

@test(expected_type = "int", expected_value = "2")
fn test_array_slice_len() -> int {
    let arr = [1, 2, 3, 4, 5];
    let sliced = arr.slice(1, 3);
    sliced.len()
}

@test(expected_type = "int", expected_value = "0")
fn test_array_slice_empty() -> int {
    let arr = [1, 2, 3, 4, 5];
    let sliced = arr.slice(2, 2);
    sliced.len()
}

@test(expected_type = "int", expected_value = "0")
fn test_array_slice_start_greater_than_end() -> int {
    let arr = [1, 2, 3, 4, 5];
    let sliced = arr.slice(3, 1);
    sliced.len()
}

@test(expected_type = "int", expected_value = "5")
fn test_array_slice_entire_array() -> int {
    let arr = [1, 2, 3, 4, 5];
    let sliced = arr.slice(0, 5);
    sliced.len()
}

@test(expected_type = "int", expected_value = "10")
fn test_array_slice_first_element_only() -> int {
    let arr = [10, 20, 30];
    let sliced = arr.slice(0, 1);
    sliced[0]
}

@test(expected_type = "int", expected_value = "30")
fn test_array_slice_last_element_only() -> int {
    let arr = [10, 20, 30];
    let sliced = arr.slice(2, 3);
    sliced[0]
}

@test(expected_type = "int", expected_value = "3")
fn test_array_slice_clamp_negative_start() -> int {
    let arr = [1, 2, 3, 4, 5];
    let sliced = arr.slice(-1, 3);
    sliced.len()
}

@test(expected_type = "int", expected_value = "5")
fn test_array_slice_clamp_end_beyond_length() -> int {
    let arr = [1, 2, 3, 4, 5];
    let sliced = arr.slice(0, 100);
    sliced.len()
}

// === Tests for array.get() ===

@test(expected_type = "int", expected_value = "2")
fn test_array_get_in_bounds() -> int {
    let arr = [1, 2, 3];
    arr.get(1) ?? -1
}

@test(expected_type = "int", expected_value = "99")
fn test_array_get_out_of_bounds() -> int {
    let arr = [1, 2, 3];
    arr.get(10) ?? 99
}

// === Tests for box<array>.push() ===

@test(expected_type = "int", expected_value = "4")
fn test_array_push_length_increases() -> int {
    let arr = [1, 2, 3];
    let boxed = box(arr);
    boxed.push(4);
    boxed.len()
}

@test(expected_type = "int", expected_value = "42")
fn test_array_push_element_accessible() -> int {
    let arr = [1, 2, 3];
    let boxed = box(arr);
    boxed.push(42);
    boxed[3]
}

@test(expected_type = "int", expected_value = "5")
fn test_array_push_multiple_times() -> int {
    let arr = [1, 2, 3];
    let boxed = box(arr);
    boxed.push(4);
    boxed.push(5);
    boxed.len()
}

@test(expected_type = "int", expected_value = "5")
fn test_array_push_last_pushed_element() -> int {
    let arr = [1, 2, 3];
    let boxed = box(arr);
    boxed.push(4);
    boxed.push(5);
    boxed[4]
}

@test(expected_type = "int", expected_value = "1")
fn test_array_push_to_empty() -> int {
    let arr: [int] = [];
    let boxed = box(arr);
    boxed.push(100);
    boxed.len()
}

@test(expected_type = "int", expected_value = "100")
fn test_array_push_to_empty_value() -> int {
    let arr: [int] = [];
    let boxed = box(arr);
    boxed.push(100);
    boxed[0]
}

// === Tests for box<array>.clear() ===

@test(expected_type = "int", expected_value = "0")
fn test_array_clear_length_zero() -> int {
    let arr = [1, 2, 3];
    let boxed = box(arr);
    boxed.clear();
    boxed.len()
}

@test(expected_type = "int", expected_value = "1")
fn test_array_clear_then_push() -> int {
    let arr = [1, 2, 3];
    let boxed = box(arr);
    boxed.clear();
    boxed.push(42);
    boxed.len()
}

@test(expected_type = "int", expected_value = "42")
fn test_array_clear_then_push_value() -> int {
    let arr = [1, 2, 3];
    let boxed = box(arr);
    boxed.clear();
    boxed.push(42);
    boxed[0]
}

@test(expected_type = "int", expected_value = "0")
fn test_array_clear_already_empty() -> int {
    let arr: array<int> = [];
    let boxed = box(arr);
    boxed.clear();
    boxed.len()
}

// === Tests for box<array>.pop() ===

@test(expected_type = "int", expected_value = "3")
fn test_array_pop_returns_last() -> int {
    let arr = [1, 2, 3];
    let boxed = box(arr);
    boxed.pop() ?? -1
}

@test(expected_type = "int", expected_value = "2")
fn test_array_pop_decreases_length() -> int {
    let arr = [1, 2, 3];
    let boxed = box(arr);
    boxed.pop();
    boxed.len()
}

@test(expected_type = "int", expected_value = "77")
fn test_array_pop_empty_returns_default() -> int {
    let arr: array<int> = [];
    let boxed = box(arr);
    boxed.pop() ?? 77
}

// === Tests for box<array>.set() ===

@test(expected_type = "int", expected_value = "2")
fn test_array_set_returns_old() -> int {
    let arr = [1, 2, 3];
    let boxed = box(arr);
    boxed.set(1, 9) ?? -1
}

@test(expected_type = "int", expected_value = "9")
fn test_array_set_updates_value() -> int {
    let arr = [1, 2, 3];
    let boxed = box(arr);
    boxed.set(1, 9);
    boxed[1]
}

@test(expected_type = "int", expected_value = "55")
fn test_array_set_out_of_bounds() -> int {
    let arr = [1, 2, 3];
    let boxed = box(arr);
    boxed.set(10, 9) ?? 55
}

// === Combined operation tests ===

@test(expected_type = "int", expected_value = "1")
fn test_array_slice_then_len() -> int {
    let arr = [1, 2, 3, 4, 5];
    let sliced = arr.slice(2, 3);
    sliced.len()
}

@test(expected_type = "int", expected_value = "3")
fn test_array_push_clear_push() -> int {
    let arr = [1, 2];
    let boxed = box(arr);
    boxed.push(3);
    boxed.clear();
    boxed.push(10);
    boxed.push(20);
    boxed.push(30);
    boxed.len()
}

@test(expected_type = "int", expected_value = "30")
fn test_array_push_clear_push_value() -> int {
    let arr = [1, 2];
    let boxed = box(arr);
    boxed.push(3);
    boxed.clear();
    boxed.push(10);
    boxed.push(20);
    boxed.push(30);
    boxed[2]
}

@test(expected_type = "int", expected_value = "20")
fn test_array_slice_sum() -> int {
    let arr = [1, 2, 3, 4, 5, 6];
    let sliced = arr.slice(1, 6);
    let sum = sliced[0] + sliced[1] + sliced[2] + sliced[3] + sliced[4];
    sum
}
