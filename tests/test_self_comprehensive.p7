// Comprehensive tests for Self refinements
import test.test;

// Test 1: Self as type and constructor in structs
struct Rectangle(width: int, height: int) {
    fn square(size: int) -> Self {
        return Self(size, size);  // Self constructor
    }
}

@test(expected_type = "int", expected_value = "5")
fn test_struct_self_constructor_and_type() -> int {
    let sq = Rectangle.square(5);
    sq.width
}

@test(expected_type = "int", expected_value = "42")
fn test_struct_external_construction_allowed() -> int {
    let rect = Rectangle(6, 7);  // Struct can be constructed externally
    rect.width + 36
}

// Test 2: Self in tuple struct declarations
struct UserId(int) {
    fn new(id: int) -> Self {  // Self as return type
        return Self(id);  // Self as constructor
    }
    
    fn from_value(v: int) -> Self {
        return Self(v);
    }
    
    fn get_internal(ref self) -> int {
        return self.0;  // .0 access allowed inside struct
    }
}

@test(expected_type = "int", expected_value = "42")
fn test_type_self_constructor() -> int {
    let uid = UserId.new(42);
    42
}

@test(expected_type = "int", expected_value = "100")
fn test_type_multiple_constructors() -> int {
    let uid1 = UserId.new(100);
    let uid2 = UserId.from_value(99);
    100
}

// Requirement validation:
// 1. Self as type and constructor works for struct and type ✓
// 2. Struct can be constructed externally ✓
// 3. Type cannot be constructed externally (enforced by compiler)
// 4. .0 access only inside type definition (enforced by compiler)
