// Test for generic functions with explicit type arguments
struct test(
    pub expected_type: string,
    pub expected_value: string,
);

// Generic identity function
fn identity<T>(x: T) -> T {
    return x;
}

// Generic function with two type parameters
fn first<T, U>(x: T, y: U) -> T {
    return x;
}

// Test calling identity with explicit type argument
@test(expected_type = "int", expected_value = "42")
fn test_identity_int() -> int {
    identity<int>(42)
}

@test(expected_type = "int", expected_value = "100")
fn test_identity_int2() -> int {
    identity<int>(100)
}

// Test calling first with explicit type arguments
@test(expected_type = "int", expected_value = "10")
fn test_first_int_int() -> int {
    first<int, int>(10, 20)
}

@test(expected_type = "float", expected_value = "3.14")
fn test_identity_float() -> float {
    identity<float>(3.14)
}
