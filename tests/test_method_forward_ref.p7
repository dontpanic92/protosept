// Test that struct/enum methods can call other methods defined later in the
// same type (forward references within a struct/enum body).

struct Calc(value: int) {
    // helper is defined AFTER compute — this tests forward reference support
    fn compute(ref self) -> int {
        return self.helper() + 10;
    }

    fn helper(ref self) -> int {
        return self.value * 2;
    }

    // Chain: a -> b -> c (all forward references)
    fn a(ref self) -> int {
        return self.b() + 1;
    }

    fn b(ref self) -> int {
        return self.c() + 1;
    }

    fn c(ref self) -> int {
        return self.value;
    }

    // Mutual: even calls odd, odd calls even (needs both registered before bodies)
    fn is_positive(ref self) -> bool {
        return self.value > 0;
    }

    fn describe(ref self) -> string {
        if self.is_positive() {
            return "pos";
        }
        return "non-pos";
    }
}

enum Direction(Up, Down, Left, Right) {
    // Forward reference: label calls code
    fn label(ref self) -> string {
        return "dir:" + self.code();
    }

    fn code(ref self) -> string {
        return "X";
    }
}

@test(expected_type = "int", expected_value = "20")
pub fn test_struct_forward_method() -> int {
    let c = box(Calc(5));
    c.compute()
}

@test(expected_type = "int", expected_value = "7")
pub fn test_struct_chain_forward() -> int {
    let c = box(Calc(5));
    c.a()
}

@test(expected_type = "string", expected_value = "pos")
pub fn test_struct_forward_bool() -> string {
    let c = box(Calc(3));
    c.describe()
}

@test(expected_type = "string", expected_value = "dir:X")
pub fn test_enum_forward_method() -> string {
    let d = box(Direction.Up);
    d.label()
}
