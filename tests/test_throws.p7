// Define the test attribute struct
struct test(
    pub expected_type: string,
    pub expected_value: string,
);

enum MyError {
    Error1,
    SomeError,
}

fn safe_function() -> int {
    5
}

fn risky_function() -> int throws {
    10
}

fn helper() -> int {
    42
}

fn risky_no_return() throws {
    let x = helper();
}

fn may_throw(value: int) -> int throws {
    if value == 0 {
        throw MyError.SomeError;
    }
    value
}

@test(expected_type = "int", expected_value = "5")
fn test_throws_syntax() -> int {
    safe_function()
}

@test(expected_type = "int", expected_value = "42")
fn test_throws_no_return() -> int {
    42
}

@test(expected_type = "int", expected_value = "42")
fn test_exception() -> int {
    let result = try may_throw(0) else 42;
    result
}
