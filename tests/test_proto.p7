// Test proto declaration syntax parsing
import test.test;

// Test proto declaration
proto Printable {
  fn print(self: ref Printable) -> unit;
  fn display(self: ref Printable) -> string;
}

struct Vec2(
  x: float,
  y: float,
);

@test(expected_type = "int", expected_value = "42")
fn test_proto_syntax_parses() -> int {
  // This test verifies the proto declaration above was accepted by the parser
  42
}
