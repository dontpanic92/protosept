// Tests for cross-module type annotations and container types
import test.test;
import cross_module_test.types;

// --- Explicit type annotations ---

@test(expected_type = "int", expected_value = "7")
fn test_let_with_type_annotation() -> int {
    let p: types.Pos = types.Pos(7, 8);
    return p.row;
}

@test(expected_type = "int", expected_value = "3")
fn test_let_enum_annotation() -> int {
    let d: types.Direction = types.Direction.Left;
    match d {
        types.Direction.Up => 1,
        types.Direction.Down => 2,
        types.Direction.Left => 3,
        types.Direction.Right => 4,
    }
}

// --- array<module.Type> ---

@test(expected_type = "int", expected_value = "2")
fn test_array_of_cross_module_type() -> int {
    let arr: array<types.Pos> = [types.Pos(1, 2), types.Pos(3, 4)];
    return arr.len();
}

@test(expected_type = "int", expected_value = "3")
fn test_array_element_field_access() -> int {
    let arr: array<types.Pos> = [types.Pos(1, 2), types.Pos(3, 4)];
    return arr[1].row;
}

// --- box<array<module.Type>> ---

@test(expected_type = "int", expected_value = "10")
fn test_box_array_cross_module() -> int {
    let arr: box<array<types.Pos>> = box([types.Pos(10, 20)]);
    return arr[0].row;
}

@test(expected_type = "int", expected_value = "30")
fn test_box_array_push_and_access() -> int {
    let arr: box<array<types.Pos>> = box([types.Pos(0, 0)]);
    arr.clear();
    arr.push(types.Pos(10, 20));
    arr.push(types.Pos(30, 40));
    return arr[1].row;
}

@test(expected_type = "int", expected_value = "50")
fn test_box_array_method_on_element() -> int {
    let arr: box<array<types.Pos>> = box([types.Pos(20, 30)]);
    return arr[0].sum();
}

// --- Cross-module type in local struct field ---

struct Wrapper(inner: types.Pos) {}

@test(expected_type = "int", expected_value = "5")
fn test_cross_module_type_in_local_struct() -> int {
    let w = Wrapper(types.Pos(5, 6));
    return w.inner.row;
}

@test(expected_type = "int", expected_value = "11")
fn test_cross_module_type_method_via_local_struct() -> int {
    let w = Wrapper(types.Pos(5, 6));
    return w.inner.sum();
}

// --- Cross-module type as function param and return ---

fn add_positions(a: types.Pos, b: types.Pos) -> types.Pos {
    return types.Pos(a.row + b.row, a.col + b.col);
}

@test(expected_type = "int", expected_value = "4")
fn test_cross_module_type_in_multi_param() -> int {
    let result = add_positions(types.Pos(1, 2), types.Pos(3, 4));
    return result.row;
}

// --- Cross-module pub let as function argument ---

fn double(x: int) -> int {
    return x * 2;
}

@test(expected_type = "int", expected_value = "200")
fn test_pub_var_as_function_arg() -> int {
    return double(types.MAX_VALUE);
}

@test(expected_type = "int", expected_value = "10")
fn test_pub_var_in_arithmetic() -> int {
    return types.MAX_VALUE / 10;
}

// --- Multiple box mutations ---

@test(expected_type = "int", expected_value = "10")
fn test_multiple_box_mutations() -> int {
    let p = box(types.Pos(1, 2));
    p.scale(10);
    return p.row;
}

@test(expected_type = "int", expected_value = "30")
fn test_box_mutation_then_method() -> int {
    let p = box(types.Pos(1, 2));
    p.scale(10);
    return p.sum();
}
