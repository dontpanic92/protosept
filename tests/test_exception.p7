struct test(
    pub expected_type: string,
    pub expected_value: string,
);

enum MyError {
    SomeError,
}

fn may_throw(value: int) -> int throws {
    if value == 0 {
        throw MyError.SomeError;
    }
    value
}

@test(expected_type = "int", expected_value = "42")
fn test_exception() -> int {
    let result = try may_throw(0) else 42;
    result
}
