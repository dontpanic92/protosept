// Test modulo and bitwise operators.
import test.test;

// ─── Modulo ──────────────────────────────────────────────

@test(expected_type = "int", expected_value = "1")
fn test_modulo_basic() -> int {
    return 10 % 3;
}

@test(expected_type = "int", expected_value = "0")
fn test_modulo_exact() -> int {
    return 9 % 3;
}

@test(expected_type = "int", expected_value = "2")
fn test_modulo_larger_divisor() -> int {
    return 2 % 5;
}

// ─── Bitwise AND ─────────────────────────────────────────

@test(expected_type = "int", expected_value = "15")
fn test_bitwise_and() -> int {
    return 255 & 15;
}

@test(expected_type = "int", expected_value = "0")
fn test_bitwise_and_zero() -> int {
    return 255 & 0;
}

@test(expected_type = "int", expected_value = "244")
fn test_bitwise_and_extract_byte() -> int {
    // Extract the blue byte from packed RGB 0xCDD6F4 = 13489908
    let color = 13489908;
    return color & 255;
}

// Value is 0xF4 = 244... let me recalculate:
// 0xCDD6F4: R=0xCD=205, G=0xD6=214, B=0xF4=244
// 244 & 255 = 244... but I wrote 200. Let me fix:
// Actually: 13489908 & 255 = 13489908 % 256 = let's compute:
// 13489908 / 256 = 52694.xxx => 52694 * 256 = 13489664, remainder = 244
// So test should expect 244. Let me use a simpler value.

@test(expected_type = "int", expected_value = "171")
fn test_bitwise_and_mask() -> int {
    // 0xAB = 171
    return 43947 & 255;
}

// ─── Bitwise OR ──────────────────────────────────────────

@test(expected_type = "int", expected_value = "255")
fn test_bitwise_or() -> int {
    return 240 | 15;
}

@test(expected_type = "int", expected_value = "15")
fn test_bitwise_or_identity() -> int {
    return 0 | 15;
}

// ─── Bitwise XOR ─────────────────────────────────────────

@test(expected_type = "int", expected_value = "240")
fn test_bitwise_xor() -> int {
    return 255 ^ 15;
}

@test(expected_type = "int", expected_value = "0")
fn test_bitwise_xor_self() -> int {
    return 42 ^ 42;
}

// ─── Precedence ──────────────────────────────────────────

@test(expected_type = "int", expected_value = "3")
fn test_modulo_precedence() -> int {
    // % has same precedence as *, higher than +
    // 2 + 7 % 3 = 2 + (7 % 3) = 2 + 1 = 3
    return 2 + 7 % 3;
}

@test(expected_type = "int", expected_value = "5")
fn test_bitwise_and_precedence() -> int {
    // & has lower precedence than ==
    // But let's test with arithmetic:
    // 7 & 5 = 5  (0b111 & 0b101 = 0b101)
    return 7 & 5;
}

@test(expected_type = "int", expected_value = "7")
fn test_bitwise_or_precedence() -> int {
    // 5 | 3 = 7  (0b101 | 0b011 = 0b111)
    return 5 | 3;
}

// ─── RGB extraction pattern ──────────────────────────────

@test(expected_type = "int", expected_value = "205")
fn test_rgb_extract_red() -> int {
    // Extract R from packed 0xCDD6F4 = 13489908
    let color = 13489908;
    return color / 65536;
}

@test(expected_type = "int", expected_value = "214")
fn test_rgb_extract_green() -> int {
    // Extract G from packed 0xCDD6F4 = 13489908
    let color = 13489908;
    return (color / 256) & 255;
}

@test(expected_type = "int", expected_value = "244")
fn test_rgb_extract_blue() -> int {
    // Extract B from packed 0xCDD6F4 = 13489908
    let color = 13489908;
    return color & 255;
}

// ─── Theme cycling pattern ───────────────────────────────

@test(expected_type = "int", expected_value = "1")
fn test_modulo_cycle() -> int {
    let current = 0;
    return (current + 1) % 3;
}

@test(expected_type = "int", expected_value = "0")
fn test_modulo_cycle_wrap() -> int {
    let current = 2;
    return (current + 1) % 3;
}
