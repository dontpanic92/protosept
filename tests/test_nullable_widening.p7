// Tests for implicit `T -> ?T` widening at checking/expected-type sites
// (p7_quirks.md #1, spec §3.5 / §15.2).
import test.test;

pub struct Cell(pub value: ?int);

// Helper functions / values used as the source of the non-null `T`.
fn make_int() -> int { 7 }

fn take_optional(x: ?int) -> int {
    x ?? -1
}

fn return_optional(flag: int) -> ?int {
    if flag != 0 {
        return 42;
    }
    return null;
}

// 1. `let r: ?T = make_t();` — non-null T flows into ?T annotation.
@test(expected_type = "int", expected_value = "7")
fn test_let_widen() -> int {
    let r: ?int = make_int();
    r ?? -1
}

// 2. Function return type ?T accepts a raw T return expression.
@test(expected_type = "int", expected_value = "42")
fn test_return_widen() -> int {
    let v = return_optional(1);
    v ?? -1
}

// 3. The same function also returns the null sentinel via the `null` literal.
@test(expected_type = "int", expected_value = "-1")
fn test_return_null() -> int {
    let v = return_optional(0);
    v ?? -1
}

// 4. Argument position: raw T may flow into a ?T parameter.
@test(expected_type = "int", expected_value = "99")
fn test_arg_widen() -> int {
    take_optional(99)
}

// 5. `??` rhs already uses expected-type plumbing; this exercises the no-op
// case where the rhs type already matches the inner type.
@test(expected_type = "int", expected_value = "5")
fn test_coalesce_no_widen() -> int {
    let x: ?int = null;
    x ?? 5
}

// 6. Field of a struct typed ?T accepts T at construction time.
@test(expected_type = "int", expected_value = "11")
fn test_struct_field_widen() -> int {
    let c = Cell(11);
    c.value ?? -1
}
