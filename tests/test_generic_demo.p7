// Demonstration of generic type system features in P7Lang
// This file showcases the basic generic syntax support that has been implemented

struct test(
    pub expected_type: string,
    pub expected_value: string,
);

// NOTE: This implementation provides syntax support for generics.
// Full semantic support will be implemented in future iterations.

// Example: Basic struct usage
struct Point(
    x: int,
    y: int,
);

@test(expected_type = "int", expected_value = "42")
fn test_syntax_support() -> int {
    let p = Point(42, 100);
    p.x
}

@test(expected_type = "int", expected_value = "200")
fn test_struct_fields() -> int {
    let p = Point(100, 200);
    p.y
}

