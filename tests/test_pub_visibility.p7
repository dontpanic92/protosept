// Test pub visibility modifier
import test.test;

pub fn public_helper() -> int {
    return 42;
}

fn private_helper() -> int {
    return 10;
}

pub struct MyStruct(
    pub x: int = 0,
    pub y: int = 0,
);

pub enum MyEnum(
    Value1,
    Value2,
);

@test(expected_type = "int", expected_value = "52")
fn test_pub_declarations() -> int {
    public_helper() + private_helper()
}
