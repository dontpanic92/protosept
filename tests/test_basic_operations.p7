// Basic operations test
struct test(
    pub expected_type: string,
    pub expected_value: string,
);

fn add(a: float, b: float) -> int {
    a + b
}

fn sub(a: float, b: float) -> float {
    return a - b;
}

struct Vec2(
    secret: int = 42,
    pub x: float = 0,
    pub y: float = 0,
);

@test(expected_type = "float", expected_value = "1.21")
fn test_basic_arithmetic() -> float {
    let a = 1.1;
    let b = 2.3;
    let c = add(a, b);
    let d = sub(c, b);

    a * d
}
