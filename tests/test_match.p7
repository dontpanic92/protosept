// Tests for match expressions
struct test(
    pub expected_type: string,
    pub expected_value: string,
);

// ===== Enum Definitions =====

enum Status(
    Pending,
    Active,
    Failed
);

enum Result(
    Ok: int,
    Err: int
);

// ===== Tests for match with literals =====

@test(expected_type = "int", expected_value = "42")
fn test_match_int_literal() -> int {
    let x = 42;
    match x {
        42 => 42,
        _ => 0,
    }
}

@test(expected_type = "int", expected_value = "1")
fn test_match_int_literal_second_arm() -> int {
    let x = 10;
    match x {
        42 => 0,
        10 => 1,
        _ => 2,
    }
}

@test(expected_type = "int", expected_value = "99")
fn test_match_int_literal_wildcard() -> int {
    let x = 123;
    match x {
        42 => 0,
        10 => 1,
        _ => 99,
    }
}

// ===== Tests for match with enum variants (unit) =====

@test(expected_type = "int", expected_value = "1")
fn test_match_enum_pending() -> int {
    let status = Status.Pending;
    match status {
        Status.Pending => 1,
        Status.Active => 2,
        Status.Failed => 3,
    }
}

@test(expected_type = "int", expected_value = "2")
fn test_match_enum_active() -> int {
    let status = Status.Active;
    match status {
        Status.Pending => 1,
        Status.Active => 2,
        Status.Failed => 3,
    }
}

@test(expected_type = "int", expected_value = "3")
fn test_match_enum_failed() -> int {
    let status = Status.Failed;
    match status {
        Status.Pending => 1,
        Status.Active => 2,
        Status.Failed => 3,
    }
}

@test(expected_type = "int", expected_value = "99")
fn test_match_enum_wildcard() -> int {
    let status = Status.Active;
    match status {
        Status.Pending => 1,
        _ => 99,
    }
}

// ===== Enum with mixed payload/no-payload variants =====

enum KeyCode(
    Unknown,
    Enter,
    Escape,
    Char: string,
);

// Test: match a no-payload variant against a payload pattern arm
@test(expected_type = "int", expected_value = "2")
fn test_match_mixed_enum_no_payload_against_payload_arm() -> int {
    let key = KeyCode.Escape;
    match key {
        KeyCode.Enter => 1,
        KeyCode.Escape => 2,
        KeyCode.Char(ch) => 3,
        _ => 0,
    }
}

// Test: match a payload variant against no-payload pattern arms
@test(expected_type = "int", expected_value = "3")
fn test_match_mixed_enum_payload_against_no_payload_arms() -> int {
    let key = KeyCode.Char("a");
    match key {
        KeyCode.Enter => 1,
        KeyCode.Escape => 2,
        KeyCode.Char(ch) => 3,
        _ => 0,
    }
}

// Test: extract payload from a payload variant in mixed enum
@test(expected_type = "string", expected_value = "hello")
fn test_match_mixed_enum_extract_payload() -> string {
    let key = KeyCode.Char("hello");
    match key {
        KeyCode.Enter => "enter",
        KeyCode.Char(ch) => ch,
        _ => "other",
    }
}

// Test: wildcard matches a no-payload variant in mixed enum
@test(expected_type = "int", expected_value = "99")
fn test_match_mixed_enum_wildcard_no_payload() -> int {
    let key = KeyCode.Unknown;
    match key {
        KeyCode.Enter => 1,
        KeyCode.Escape => 2,
        KeyCode.Char(ch) => 3,
        _ => 99,
    }
}

// Test: wildcard matches a payload variant in mixed enum
@test(expected_type = "int", expected_value = "99")
fn test_match_mixed_enum_wildcard_payload() -> int {
    let key = KeyCode.Char("x");
    match key {
        KeyCode.Enter => 1,
        KeyCode.Escape => 2,
        _ => 99,
    }
}

// Test: payload pattern is first arm, scrutinee is no-payload
@test(expected_type = "int", expected_value = "2")
fn test_match_payload_first_arm_no_payload_scrutinee() -> int {
    let key = KeyCode.Enter;
    match key {
        KeyCode.Char(ch) => 1,
        KeyCode.Enter => 2,
        _ => 0,
    }
}

// Test: multiple no-payload arms before payload arm
@test(expected_type = "string", expected_value = "z")
fn test_match_many_no_payload_then_payload() -> string {
    let key = KeyCode.Char("z");
    match key {
        KeyCode.Unknown => "u",
        KeyCode.Enter => "e",
        KeyCode.Escape => "esc",
        KeyCode.Char(ch) => ch,
        _ => "other",
    }
}

// ===== Tests for match with variable binding =====

@test(expected_type = "int", expected_value = "42")
fn test_match_bind_variable() -> int {
    let x = 42;
    match x {
        val: 42 => val,
        _ => 0,
    }
}

@test(expected_type = "int", expected_value = "999")
fn test_match_bind_wildcard() -> int {
    let x = 999;
    match x {
        42 => 42,
        other: _ => other,
    }
}

@test(expected_type = "int", expected_value = "123")
fn test_match_enum_bind_wildcard() -> int {
    let status = Status.Active;
    match status {
        Status.Pending => 1,
        s: _ => 123,
    }
}
