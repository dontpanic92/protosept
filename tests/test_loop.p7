// Tests for loop statement with break
// Note: These tests only verify break statements work in loops.
// They do NOT test actual iteration (the loops break immediately)
// or continue statements. Testing iteration would require mutable state.
import test.test;

// ===== Loop Break Tests =====

@test(expected_type = "int", expected_value = "42")
fn test_loop_break_immediately() -> int {
    loop {
        break;
    }
    42
}

@test(expected_type = "int", expected_value = "1")
fn test_loop_with_condition_break() -> int {
    let x = 5;
    loop {
        if x == 5 {
            break;
        }
    }
    1
}

@test(expected_type = "int", expected_value = "2")
fn test_loop_nested_break() -> int {
    loop {
        loop {
            break;
        }
        break;
    }
    2
}
