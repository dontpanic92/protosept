// Test string method support
import test.test;

@test(expected_type = "int", expected_value = "5")
fn test_string_len_bytes_hello() -> int {
    let s = "hello";
    s.len_bytes()
}

@test(expected_type = "int", expected_value = "0")
fn test_string_len_bytes_empty() -> int {
    let s = "";
    s.len_bytes()
}

@test(expected_type = "int", expected_value = "13")
fn test_string_len_bytes_punctuation() -> int {
    "Hello, World!".len_bytes()
}

@test(expected_type = "int", expected_value = "3")
fn test_string_len_bytes_abc() -> int {
    "abc".len_bytes()
}

@test(expected_type = "int", expected_value = "27")
fn test_string_len_bytes_long() -> int {
    "abcdefghijklmnopqrstuvwxyz!".len_bytes()
}
