// Test type construction, field access, and method calling
import test.test;

// Type with representation
type UserId(int) {
    pub fn new(id: int) -> UserId {
        return Self(id);
    }
    
    pub fn value(ref self) -> int {
        return self.0;
    }
    
    pub fn increment(ref self) -> UserId {
        return Self(self.0 + 1);
    }
}

@test(expected_type = "int", expected_value = "42")
fn test_type_construction() -> int {
    let uid = UserId.new(42);
    uid.value()
}

@test(expected_type = "int", expected_value = "100")
fn test_type_field_access() -> int {
    let uid = UserId.new(100);
    uid.0
}

@test(expected_type = "int", expected_value = "43")
fn test_type_method_chain() -> int {
    let uid = UserId.new(42);
    let uid2 = uid.increment();
    uid2.value()
}

// Type with Copy conformance
type[Copy] Counter(int) {
    pub fn zero() -> Counter {
        return Self(0);
    }
    
    pub fn inc(ref self) -> Counter {
        return Self(self.0 + 1);
    }
    
    pub fn get(ref self) -> int {
        return self.0;
    }
}

@test(expected_type = "int", expected_value = "0")
fn test_type_copy() -> int {
    let c1 = Counter.zero();
    let c2 = c1;  // Should work because Counter is Copy
    let c3 = c1;  // Should also work
    c1.get()
}

@test(expected_type = "int", expected_value = "3")
fn test_type_copy_increment() -> int {
    let c = Counter.zero();
    let c1 = c.inc();
    let c2 = c1.inc();
    let c3 = c2.inc();
    c3.get()
}
