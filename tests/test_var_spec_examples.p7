// Comprehensive test based on spec examples
import test.test;

@test(expected_type = "int", expected_value = "10")
fn test_spec_loop_accumulator() -> int {
    let mut total = 0;
    let mut i = 1;
    loop {
        if i > 4 {
            break;
        }
        total = total + i;
        i = i + 1;
    }
    total
}

@test(expected_type = "int", expected_value = "30")
fn test_spec_var_shadowing() -> int {
    let x = 10;
    let result = {
        let mut x = 20;
        x = 30;
        x
    };
    result
}

@test(expected_type = "int", expected_value = "50")
fn test_var_multiple_reassign() -> int {
    let mut x = 10;
    x = 20;
    x = 30;
    x = 40;
    x = 50;
    x
}

@test(expected_type = "int", expected_value = "99")
fn test_var_type_annotation() -> int {
    let mut count: int = 0;
    count = 99;
    count
}

@test(expected_type = "int", expected_value = "25")
fn test_var_type_consistency() -> int {
    let mut x = 5;
    x = 10;
    x = x + 15;
    x
}
