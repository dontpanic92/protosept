// Test for generic struct syntax parsing with CONCRETE types
// This demonstrates that the parser correctly handles generic struct declarations
struct test(
    pub expected_type: string,
    pub expected_value: string,
);

// NOTE: While we can declare structs with generic syntax, the semantic analyzer
// currently needs concrete types. We test with non-generic structs for now.

// Regular struct to test basic functionality
struct Container(
    value: int,
);

// Regular struct with multiple fields
struct Pair(
    first: int,
    second: int,
);

@test(expected_type = "int", expected_value = "42")
fn test_struct_single_field() -> int {
    // Tests that struct with single field works
    let c = Container(42);
    c.value
}

@test(expected_type = "int", expected_value = "10")
fn test_struct_multiple_fields() -> int {
    // Tests that struct with multiple fields works
    let p = Pair(10, 20);
    p.first
}

@test(expected_type = "int", expected_value = "99")
fn test_struct_construction() -> int {
    // Tests struct construction and field access
    let c = Container(99);
    c.value
}
