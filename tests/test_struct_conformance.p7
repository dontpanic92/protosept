// Test struct protocol conformance
import test.test;

// Define a simple protocol
proto Printable {
  fn print(self: ref Printable) -> unit;
}

proto Displayable {
  fn display(self: ref Displayable) -> int;
}

// Struct conforming to Printable
struct[Printable] Point(
  x: int,
  y: int,
) {
  pub fn print(self: ref Point) -> unit {
    // Implementation
  }
}

// Struct conforming to multiple protocols
struct[Printable, Displayable] Vec2(
  x: float,
  y: float,
) {
  pub fn print(self: ref Vec2) -> unit {
    // Implementation
  }
  
  pub fn display(self: ref Vec2) -> int {
    42
  }
}

// Test that structs can be created
@test(expected_type = "int", expected_value = "42")
fn test_conformance_basic() -> int {
  let p = Point(x = 10, y = 20);
  42
}

@test(expected_type = "int", expected_value = "42")
fn test_conformance_multiple() -> int {
  let v = Vec2(x = 1.0, y = 2.0);
  v.display()
}

