pub struct Pos(pub row: int, pub col: int) {
    pub fn sum(ref self) -> int {
        return self.row + self.col;
    }

    pub fn scale(box self, factor: int) {
        self.row = self.row * factor;
        self.col = self.col * factor;
    }

    pub fn origin() -> Pos {
        return Pos(0, 0);
    }

    pub fn from_value(v: int) -> Pos {
        return Pos(v, v);
    }
}

pub enum Direction(Up, Down, Left, Right) {
    pub fn is_vertical(ref self) -> bool {
        match self {
            Direction.Up => true,
            Direction.Down => true,
            _ => false,
        }
    }

    pub fn default() -> Direction {
        return Direction.Up;
    }
}

pub enum Shape(
    Circle: int,
    Square: int,
) {
    pub fn unit_circle() -> Shape {
        return Shape.Circle(1);
    }

    pub fn get_value(ref self) -> int {
        match self {
            Shape.Circle(r) => r,
            Shape.Square(s) => s,
        }
    }
}

pub fn make_pos(r: int, c: int) -> Pos {
    return Pos(r, c);
}

pub fn get_row(p: Pos) -> int {
    return p.row;
}

// Public module-level bindings (accessible cross-module)
pub let MAX_VALUE: int = 100;
pub let ORIGIN: Pos = Pos(0, 0);
pub let mut counter: int = 0;

// Private module-level binding (NOT accessible cross-module)
let secret: int = 42;
