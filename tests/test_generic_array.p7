// Test for generic array<T> type annotation syntax parsing
struct test(
    pub expected_type: string,
    pub expected_value: string,
);

// Test using generic type syntax with concrete type in function signature
// Demonstrates that array<int> syntax is recognized by parser
fn sum_array(length: int) -> int {
    length
}

struct Container(
    size: int,
);

@test(expected_type = "int", expected_value = "5")
fn test_array_syntax_parsing() -> int {
    // This validates that array<int> type syntax can be used
    sum_array(5)
}

@test(expected_type = "int", expected_value = "10")
fn test_container() -> int {
    let c = Container(10);
    c.size
}
