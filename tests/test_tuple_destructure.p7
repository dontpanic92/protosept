// Tuple destructuring and pattern matching tests
import test.test;

fn pair() -> (int, int) {
    return (10, 20);
}

@test(expected_type = "int", expected_value = "1")
fn test_tuple_destructure_first() -> int {
    let (a, b) = (1, 2);
    a
}

@test(expected_type = "int", expected_value = "2")
fn test_tuple_destructure_second() -> int {
    let (a, b) = (1, 2);
    b
}

@test(expected_type = "int", expected_value = "3")
fn test_tuple_destructure_sum() -> int {
    let (a, b) = (1, 2);
    a + b
}

@test(expected_type = "string", expected_value = "hello")
fn test_tuple_destructure_mixed() -> string {
    let (n, s) = (42, "hello");
    s
}

@test(expected_type = "int", expected_value = "42")
fn test_tuple_destructure_mixed_int() -> int {
    let (n, s) = (42, "hello");
    n
}

@test(expected_type = "int", expected_value = "6")
fn test_tuple_destructure_triple() -> int {
    let (a, b, c) = (1, 2, 3);
    a + b + c
}

@test(expected_type = "int", expected_value = "10")
fn test_tuple_destructure_wildcard() -> int {
    let (a, _) = (10, 20);
    a
}

@test(expected_type = "int", expected_value = "30")
fn test_tuple_destructure_from_function() -> int {
    let (a, b) = pair();
    a + b
}

@test(expected_type = "int", expected_value = "100")
fn test_var_tuple_destructure() -> int {
    var (x, y) = (50, 50);
    x + y
}

@test(expected_type = "int", expected_value = "1")
fn test_tuple_match_pattern() -> int {
    let t = (1, 2);
    match t {
        (a, b) => a,
    }
}

@test(expected_type = "int", expected_value = "3")
fn test_tuple_match_sum() -> int {
    let t = (1, 2);
    match t {
        (a, b) => a + b,
    }
}
