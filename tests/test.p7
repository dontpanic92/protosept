/*
[testcase]
entrypoint = "test"
expected_type = "float"
expected_value = "1.21"
*/

enum SomeErrors {
    NumberIsNot42,
}

fn add(a: int, b: int) -> int {
    a + b
}

fn sub(a: float, b: float) -> float {
    return a - b;
}

fn[throws] test42(a: float) -> float {
    if a != 42 {
        throw NumberIsNot42;
    }

    a
}

fn assign42(a: &float) {
    a = 42;
}

struct Vec2(
    secret: int = 42,
    pub x: float = 0,
    pub y: float = 0,
){
    pub fn add(self, other: Self) -> Self {
        Self(x = self.x + other.x, y = self.y + other.y)
    }

    pub fn get_secret(self) -> int {
        self.secret
    }

    pub fn set_secret(&self, value: int) {
        self.secret = value;
    }
}

fn test() -> int {
    let a = Vec2(1, 2.5);
    let b = Vec2(3, 4.5);
    let c = a.add(b);
    let d = sub(a.x, b.y);
    
    let e = try test42(d) else {
        err: SomeErrors.NumberIsNot42 => 0,
    };

    let f = try test42(d) else 0;
    let g = try test42(d);

    assign42(&f);

    f
}
