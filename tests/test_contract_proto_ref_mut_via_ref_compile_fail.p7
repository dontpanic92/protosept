// compile_fail: calling a `ref mut self` proto method via `ref<P>` is ERROR
// (spec §18.4.1, §18.7).

proto Ticker {
    fn tick(ref mut self);
}

struct[Ticker] Tally(pub n: int) {
    pub fn tick(ref mut self) { self.n = self.n + 1; }
}

fn main() -> int {
    let mut t = Tally(0);
    let r: ref<Ticker> = ref(t) as ref<Ticker>;
    r.tick();
    return 0;
}
