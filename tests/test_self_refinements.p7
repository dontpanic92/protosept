// Test Self refinements according to requirements
import test.test;

// Requirement 1: Self as type in method declarations
struct Point(x: int, y: int) {
    fn identity(self: Self) -> Self {
        return self;
    }
}

struct UserId(int) {
    fn new(id: int) -> Self {
        return Self(id);
    }
    
    fn get_value(ref self) -> int {
        return self.0;
    }
}

// Requirement 2: struct with pub fields can be constructed outside
@test(expected_type = "int", expected_value = "42")
fn test_struct_external_construct() -> int {
    let p = Point(42, 100);
    p.x
}

@test(expected_type = "int", expected_value = "42")
fn test_type_must_use_method() -> int {
    let uid = UserId.new(42);
    42
}

// Note: UserId has private field, so it cannot be constructed externally
