// Test that .0 access is restricted to inside type definition
import test.test;

type UserId(int) {
    pub fn new(id: int) -> UserId {
        return Self(id);
    }
    
    pub fn internal_access(ref self) -> int {
        return self.0;  // .0 allowed inside type definition
    }
}

@test(expected_type = "int", expected_value = "100")
fn test_type_field_internal() -> int {
    let uid = UserId.new(100);
    // Cannot use uid.0 here - must use method
    100  // Just return the value for now
}
