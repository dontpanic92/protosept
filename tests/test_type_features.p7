// Test type construction and field access
import test.test;

type UserId(int) {
    fn new(id: int) -> UserId {
        return Self(id);
    }
}

@test(expected_type = "int", expected_value = "42")
fn test_type_constructor() -> int {
    let uid = UserId.new(42);
    42
}

@test(expected_type = "int", expected_value = "100")
fn test_type_field() -> int {
    let uid = UserId.new(100);
    uid.0
}
