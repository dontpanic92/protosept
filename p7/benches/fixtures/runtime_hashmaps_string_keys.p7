fn main() -> int {
    let values = box({"a": 1, "b": 2, "c": 3, "d": 4, "e": 5, "f": 6, "g": 7, "h": 8});
    let mut total = 0;
    let mut i = 0;
    loop {
        if i >= 1000 {
            break;
        }
        total = total + values["a"] + values["d"] + values["h"];
        if values.contains_key("missing") {
            total = total + 100;
        }
        values.set("c", values["c"] + 1);
        i = i + 1;
    }
    total + (values.get("missing") ?? 11)
}
