fn main() -> int {
    let values = box({0: 0});
    let mut i = 1;
    loop {
        if i > 1200 {
            break;
        }
        values.set(i, i * 3);
        i = i + 1;
    }

    let mut total = 0;
    let mut j = 0;
    loop {
        if j > 1200 {
            break;
        }
        total = total + values[j];
        if values.contains_key(j + 2000) {
            total = total + 1;
        }
        j = j + 1;
    }
    total + values.len()
}
