fn step(x: int) -> int {
    (x * 3) + 1
}

fn combine(a: int, b: int, c: int) -> int {
    step(a) + step(b) - step(c)
}

fn main() -> int {
    let mut total = 0;
    let mut i = 0;
    loop {
        if i > 400 {
            break;
        }
        total = total + combine(i, i + 1, i / 2);
        i = i + 1;
    }
    total
}
